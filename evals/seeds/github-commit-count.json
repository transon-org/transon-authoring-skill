{
  "origin": "real-world-pack",
  "source_ref": "docs/proposals/big-real-world-transform-samples.md §3 — GitHub push webhook",
  "template": {
    "$": "object",
    "fields": {
      "repo": {
        "$": "attr",
        "names": [
          "repository",
          "full_name"
        ]
      },
      "commitCount": {
        "$": "chain",
        "funcs": [
          {
            "$": "attr",
            "name": "commits"
          },
          {
            "$": "expr",
            "op": "+",
            "values": {
              "$": "map",
              "item": 1
            }
          }
        ]
      }
    }
  }
}
