{
  "origin": "real-world-pack",
  "source_ref": "GitHub push webhook payload — constructed from the public API reference (AD-023 real-world pack §3)",
  "template": {
    "$": "object",
    "fields": {
      "channel": "#deploys",
      "text": {
        "$": "chain",
        "funcs": [
          {
            "$": "object",
            "fields": {
              "pusher": {
                "$": "attr",
                "names": [
                  "pusher",
                  "name"
                ]
              },
              "n": {
                "$": "chain",
                "funcs": [
                  {
                    "$": "attr",
                    "name": "commits"
                  },
                  {
                    "$": "expr",
                    "op": "+",
                    "values": {
                      "$": "map",
                      "item": 1
                    }
                  }
                ]
              },
              "repo": {
                "$": "attr",
                "names": [
                  "repository",
                  "full_name"
                ]
              }
            }
          },
          {
            "$": "format",
            "pattern": "{pusher} pushed {n} commits to {repo}"
          }
        ]
      }
    }
  }
}
