{
  "origin": "real-world-pack",
  "source_ref": "GitHub push webhook payload — constructed from the public API reference (AD-023 real-world pack §3)",
  "template": {
    "$": "object",
    "fields": {
      "event": "push",
      "repo": {
        "$": "attr",
        "names": [
          "repository",
          "full_name"
        ]
      },
      "headSha": {
        "$": "attr",
        "name": "after"
      },
      "pusher": {
        "$": "attr",
        "names": [
          "pusher",
          "name"
        ]
      },
      "commitCount": {
        "$": "chain",
        "funcs": [
          {
            "$": "attr",
            "name": "commits"
          },
          {
            "$": "expr",
            "op": "+",
            "values": {
              "$": "map",
              "item": 1
            }
          }
        ]
      },
      "filesChanged": {
        "$": "chain",
        "funcs": [
          {
            "$": "attr",
            "name": "commits"
          },
          {
            "$": "expr",
            "op": "+",
            "values": {
              "$": "map",
              "item": {
                "$": "expr",
                "op": "+",
                "values": [
                  {
                    "$": "attr",
                    "name": "added"
                  },
                  {
                    "$": "attr",
                    "name": "removed"
                  },
                  {
                    "$": "attr",
                    "name": "modified"
                  }
                ]
              }
            }
          }
        ]
      },
      "deploy": {
        "$": "expr",
        "op": "==",
        "values": [
          {
            "$": "attr",
            "name": "ref"
          },
          "refs/heads/main"
        ]
      }
    }
  }
}
