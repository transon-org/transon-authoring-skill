{
  "schema_version": "1.0",
  "id": "ec2-flatten-inventory",
  "expect": "matched",
  "intent_nl": "Flatten an AWS EC2 describe-instances response (Reservations[].Instances[]) into one row per instance: id from InstanceId; pivot the Tags array so Name, Environment and Team become the fields name/env/team (null when the tag is absent); type from InstanceType; state from State.Name; az from Placement.AvailabilityZone; vpc from VpcId; privateIp from PrivateIpAddress; publicIp from PublicIpAddress (null when absent); and volumes as the list of BlockDeviceMappings[].Ebs.VolumeId.",
  "samples": {
    "schema_version": "1.0",
    "intent_nl": "Flatten an AWS EC2 describe-instances response (Reservations[].Instances[]) into one row per instance: id from InstanceId; pivot the Tags array so Name, Environment and Team become the fields name/env/team (null when the tag is absent); type from InstanceType; state from State.Name; az from Placement.AvailabilityZone; vpc from VpcId; privateIp from PrivateIpAddress; publicIp from PublicIpAddress (null when absent); and volumes as the list of BlockDeviceMappings[].Ebs.VolumeId.",
