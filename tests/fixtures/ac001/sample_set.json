{
  "schema_version": "1.0",
  "intent_nl": "Flatten each order's line items with the customer name: emit one flat list with a row per line item, each row carrying the owning order's id and customer name; keep an optional per-item note when present.",
  "coverage": [
    {
      "id": "ob-happy",
      "kind": "happy_path",
