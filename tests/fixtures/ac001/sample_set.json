    {
      "id": "ob-orders-many",
      "kind": "list_many",
      "target": "/orders",
      "description": "At least one case has two or more orders.",
      "acceptance": "accepted"
    },
    {
      "id": "ob-orders-empty",
      "kind": "list_empty",
      "target": "/orders",
      "description": "An empty orders list yields an empty flat list.",
      "acceptance": "accepted"
    },
    {
      "id": "ob-items-empty",
      "kind": "list_empty",
      "target": "/orders/0/line_items",
      "description": "An order with no line items contributes no rows.",
      "acceptance": "accepted"
