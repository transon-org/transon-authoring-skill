{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvalRunner",
  "description": "SPEC 11.8 evals/runner.json (AD-020, FR-017). Committed values are gate identity; changing any is an explicit eval-policy commit (OQ-017f pins the initial values).",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "model_id",
    "temperature",
    "max_output_tokens",
    "tool_budget",
    "runs_per_fixture",
    "pass_rule",
    "seed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "provider": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "temperature": {
      "const": 0
    },
    "max_output_tokens": {
      "type": "number"
    },
    "tool_budget": {
      "description": "caps total tool calls per run (OQ-017c)",
      "type": "number"
    },
    "runs_per_fixture": {
      "const": 3
    },
    "pass_rule": {
      "const": "majority"
    },
    "seed": {
      "description": "passed through when the provider supports it (OQ-017c)",
      "type": ["number", "null"]
    }
  }
}
